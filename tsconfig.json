{
  "extends": [
    "@tsconfig/strictest/tsconfig",
    "@tsconfig/node24/tsconfig",
    "astro/tsconfigs/strict"
  ],
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
