{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true
  },
  "assist": {
    "enabled": true
  },
  "overrides": [
    {
      "includes": ["app/routes/_renderer.tsx"],
      "linter": {
        "rules": {
          "style": {
            "useShorthandFunctionType": "off"
          }
        }
      }
    }
  ]
}
