---
// 和暦西暦対比表ページ

// 明治以降の元号ごとのセクションを作成し、各年の和暦と西暦を対比させる表を表示する
// 現在の年から降順で表示する
// 例：
// ## 令和
// | 和暦 | 西暦 |
// | --- | --- |
// | 8年 | 2026年 |
// | 7年 | 2025年 |

// ## 平成
// | 和暦 | 西暦 |
// | --- | --- |
// | 31年 | 2019年 |

// セクションはページ内リンクでアクセスできるようにする
// クエリパラメータで元号を指定することもでき、指定した場合はその元号のセクションのみを表示する（例：?era=令和）
// TODO: SSGなのでクエリパラメータでの制御は難しい
import { Card, CardContent } from '@/components/ui/card';
import {
  Table,
  TableHeader,
  TableBody,
  TableRow,
  TableHead,
  TableCell,
} from '@/components/ui/table';
import { ERAS } from '@/domain/wareki/era.js';
import TocSheet from '@/components/toc/TocSheet';
import '@/styles/global.css';
import Toc from '@/components/toc/Toc';

const { era: eraParam } = Astro.params;

const url = new URL(Astro.request.url);
const now = new Date();
const currentYear = now.getFullYear();

function anchorId(name: string) {
  return name.replace(/\s+/g, '-');
}

function yearsForEra(startYear: number, endSeirekiYear: number) {
  const maxYear = endSeirekiYear - (startYear - 1);
  const res: number[] = [];
  for (let y = Math.max(maxYear, 1); y >= 1; y--) res.push(y);
  return res;
}

const eras = eraParam ? ERAS.filter((e) => e.name === eraParam) : ERAS;
const tocItems = eras.map((e) => e.name);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': url.href,
      url: url.href,
      name: '和暦/西暦 対比表 - 元号別の年号一覧',
      description:
        '明治以降の日本の元号（令和、平成など）と西暦を対比させた一覧表。元号ごとにセクション分けされており、各年の和暦と西暦を簡単に確認できます。',
    },
  ],
} as const;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>和暦/西暦 対比表 - 元号別の年号一覧</title>
    {/* Primary Meta Tags */}
    <meta name="title" content="和暦/西暦 対比表 - 元号別の年号一覧" />
    <meta name="description" content="明治以降の日本の元号（令和、平成など）と西暦を対比させた一覧表。元号ごとにセクション分けされており、各年の和暦と西暦を簡単に確認できます。" />
    {/* Open Graph / Facebook */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url.href} />
    <meta property="og:title" content="和暦/西暦 対比表" />
    <meta property="og:description" content="明治以降の日本の元号と西暦を対比させた一覧表。元号ごとの年号変換に便利です。" />
    {/* TODO: og:image を指定 */}
    {/* Twitter */}
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={url.href} />
    <meta property="twitter:title" content="和暦/西暦 対比表" />
    <meta property="twitter:description" content="明治以降の日本の元号と西暦を対比させた一覧表。元号ごとの年号変換に便利です。" />
    {/* TODO: twitter:image を指定 */}
    {/* Canonical URL */}
    <link rel="canonical" href={url.href} />
    {/* TODO: JSON-LD 構造化データ (BreadcrumbList, FAQSchema など) を追加 */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    {/* TODO: サイトマップとrobots.txtの設定確認 */}
  </head>
  <body class="antialiased">
    <header class="sticky top-0 z-30 h-[3rem] bg-white border-b grid grid-cols-[1fr_auto] items-center justify-between px-4">
      <h1 class="text-2xl font-bold truncate">和暦/西暦 対比表</h1>
      <div class="md:hidden">
        <TocSheet client:load items={tocItems} />
      </div>
    </header>
    <div class="my-8 mx-auto px-4 max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_200px] gap-6 items-start">
        <main class="min-w-0 grid grid-cols-1 gap-8 items-start">
          {
            eras.map((era) => {
              const eraEndSeirekiYear = era.end?.year ?? currentYear;
              const maxYear = eraEndSeirekiYear - (era.start.year - 1);
              if (maxYear < 1) return null;
              return (
                <section
                  id={anchorId(era.name)}
                  style={`scroll-margin-top: 3rem`}
                >
                  <h2 class="sticky top-[3rem] z-20 bg-white/70 backdrop-blur-md text-xl font-semibold px-2 py-2 rounded-xl">
                    {era.name}
                  </h2>
                  <Card className="mt-2 p-0">
                    <CardContent className="p-0">
                      <Table>
                        <TableHeader>
                          <tr class="bg-slate-50">
                            <TableHead className="text-left px-3 py-2">
                              和暦
                            </TableHead>
                            <TableHead className="text-left px-3 py-2 border-l">
                              西暦
                            </TableHead>
                          </tr>
                        </TableHeader>
                        <TableBody>
                          {yearsForEra(era.start.year, eraEndSeirekiYear).map(
                            (wy) => {
                              const sy = era.start.year - 1 + wy;
                              return (
                                <TableRow
                                  className="hover:bg-slate-50"
                                  key={`${era.name}-${wy}`}
                                >
                                  <TableCell className="px-3 py-2">
                                    {wy}年
                                  </TableCell>
                                  <TableCell className="px-3 py-2 border-l">
                                    {sy}年
                                  </TableCell>
                                </TableRow>
                              );
                            },
                          )}
                        </TableBody>
                      </Table>
                    </CardContent>
                  </Card>
                </section>
              );
            })
          }
        </main>

        <aside class="hidden md:block md:sticky md:top-24 w-48 max-h-[calc(100vh-4rem)] overflow-auto self-start">
          <Toc items={tocItems} />
        </aside>
      </div>
    </div>
  </body>
</html>
