---
// 和暦西暦対比表ページ

// 明治以降の元号ごとのセクションを作成し、各年の和暦と西暦を対比させる表を表示する
// 現在の年から降順で表示する
// 例：
// ## 令和
// | 和暦 | 西暦 |
// | --- | --- |
// | 8年 | 2026年 |
// | 7年 | 2025年 |

// ## 平成
// | 和暦 | 西暦 |
// | --- | --- |
// | 31年 | 2019年 |

// セクションはページ内リンクでアクセスできるようにする
// クエリパラメータで元号を指定することもでき、指定した場合はその元号のセクションのみを表示する（例：?era=令和）
import { Card, CardContent } from "@/components/ui/card";
import {
  Table,
  TableHeader,
  TableBody,
  TableRow,
  TableHead,
  TableCell,
} from "@/components/ui/table";
import { ERAS } from "@/domain/wareki/era.js";
import TocFab from "@/components/toc/TocSheet";
import "@/styles/global.css";
import Toc from "@/components/toc/Toc";

const url = new URL(Astro.request.url);
const eraParam = url.searchParams.get("era") ?? null;
const now = new Date();
const currentYear = now.getFullYear();

function anchorId(name: string) {
  return name.replace(/\s+/g, "-");
}

function yearsForEra(startYear: number, endSeirekiYear: number) {
  const maxYear = endSeirekiYear - (startYear - 1);
  const res: number[] = [];
  for (let y = Math.max(maxYear, 1); y >= 1; y--) res.push(y);
  return res;
}

const eras = eraParam ? ERAS.filter((e) => e.name === eraParam) : ERAS;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>和暦／西暦 対比表</title>
  </head>
  <body class="antialiased">
    <header>
      <h1 class="text-2xl font-bold">和暦／西暦 対比表</h1>
      <p class="text-sm text-muted-foreground">
        現在の年から降順で表示します。クエリで元号を指定するとその元号のみ表示されます（例:
        <a class="underline" href="?era=令和">?era=令和</a>）。
      </p>
    </header>
    <aside class="block lg:hidden sticky top-0 z-30 bg-white border-b">
      <TocFab client:load items={ERAS.map((e) => e.name)} />
    </aside>
    <div class="prose mx-auto my-8 px-4 max-w-5xl">
      <div
        class="page-layout grid grid-cols-1 lg:grid-cols-[1fr_200px] gap-6 items-start"
      >
        <main class="min-w-0">
          {
            eras.map((era) => {
              const eraEndSeirekiYear = era.end?.year ?? currentYear;
              const maxYear = eraEndSeirekiYear - (era.start.year - 1);
              if (maxYear < 1) return null;
              return (
                <section
                  id={anchorId(era.name)}
                  class="my-8"
                  style={`scroll-margin-top: 6rem`}
                >
                  <h2 class="sticky top-8 z-20 bg-white text-xl font-semibold px-3 py-2">
                    {era.name}
                  </h2>
                  <div class="mt-12">
                    <Card className="p-0">
                      <CardContent className="p-0">
                        <Table>
                          <TableHeader>
                            <tr class="bg-slate-50">
                              <TableHead className="text-left px-3 py-2 border">
                                和暦
                              </TableHead>
                              <TableHead className="text-left px-3 py-2 border">
                                西暦
                              </TableHead>
                            </tr>
                          </TableHeader>
                          <TableBody>
                            {yearsForEra(era.start.year, eraEndSeirekiYear).map(
                              (wy) => {
                                const sy = era.start.year - 1 + wy;
                                return (
                                  <TableRow
                                    className="hover:bg-slate-50"
                                    key={`${era.name}-${wy}`}
                                  >
                                    <TableCell className="px-3 py-2 border">
                                      {wy}年
                                    </TableCell>
                                    <TableCell className="px-3 py-2 border">
                                      {sy}年
                                    </TableCell>
                                  </TableRow>
                                );
                              },
                            )}
                          </TableBody>
                        </Table>
                      </CardContent>
                    </Card>
                  </div>
                </section>
              );
            })
          }
        </main>

        <aside
          class="hidden lg:block lg:sticky lg:top-24 w-48 max-h-[calc(100vh-4rem)] overflow-auto self-start"
        >
          <Toc items={ERAS.map((e) => e.name)} />
        </aside>
      </div>
    </div>
  </body>
</html>
